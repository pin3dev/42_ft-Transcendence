{
  "compilerOptions": {
    "target": "ES2020",               // Compila para o ES2020
    "module": "commonjs",             // Gera código CommonJS (compatível com require/exports)
    "moduleResolution": "node",       // Resolução de módulos no estilo Node.js
    "lib": ["ES2020", "DOM"],         // Biblioteca para compatibilidade de recursos ES2020
    "outDir": "./src",                // Gera os arquivos transpilados na pasta 'dist'
    "esModuleInterop": true,          // Garante compatibilidade com módulos comuns
    "strict": true,                   // Modo estrito para evitar erros
    "declaration": false,             // Não gera arquivos .d.ts
    "sourceMap": false,               // Não gera mapas de fontes
    "removeComments": true,           // Remove os comentários do código transpilado
    "baseUrl": "./",                  // Base para resolução de caminhos
    "paths": {
      "redis/modules.js": ["../../../../pckg/redis/modules.js"]
    }
  },
  "include": ["src_ts"],             // Inclui a pasta 'src_ts' no TypeScript
  "exclude": ["node_modules", "tests"] // Exclui 'node_modules' e 'tests'
}
